# ============================================================
# DRIFTFIELD: Environment Variables
# ============================================================
# Copy this to .env.local for development.
# Set these in Vercel Dashboard > Settings > Environment Variables for production.
# ============================================================

# --- SUPABASE ---
# Found in: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - SERVER SIDE ONLY (api/ functions)
# NEVER prefix with VITE_ (would expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Also set without VITE_ prefix for API routes
SUPABASE_URL=https://your-project.supabase.co

# --- STRIPE ---
# Found in: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...

# Found in: Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs - Created in Stripe Dashboard > Products
# Monthly: $1.99/month subscription
VITE_STRIPE_PRICE_MONTHLY=price_...
# Yearly: $11.99/year subscription
VITE_STRIPE_PRICE_YEARLY=price_...

# --- AI / LLM ---
# Anthropic API key — used by api/reading-narrative.js for premium narratives
# Found in: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Gemini API key — used by api/generate-card-back.js for AI card back generation
# Found in: aistudio.google.com > API Keys
GEMINI_API_KEY=AI...

# --- APP ---
# Your production URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://driftfield.app

# --- CRON ---
# Secret for verifying Vercel cron job requests
# Set to any random string; Vercel sends it as Authorization header
CRON_SECRET=your-random-secret-here
